# 复制为 .env 后填写。勿将含真实密钥的 .env 提交到仓库。
VITE_APP_ALI_QIANWEN_API_KEY=
VITE_ALI_QWEN_API_MODEL=qwen3.6-plus

# 通义百炼「模型 id」（短名）。界面里若选的是 HF 长名（如 Qwen/Qwen3-...），会自动回落到此模型。
# 未开通付费模型时一般用 qwen-turbo；已开通可改为 qwen-plus、qwen-max 等。
# VITE_ALI_QWEN_API_MODEL=qwen-turbo

# DashScope 地域须与控制台创建 Key 的地域一致（否则易 HTTP 404）
# 华北2（北京）地域 Key：可不写下面两项，默认即为北京节点
#   请求根域名：https://dashscope.aliyuncs.com
# 若曾调试改过地域，请删去 singapore 相关配置，或显式写：
# VITE_DASHSCOPE_REGION=beijing

# 非北京地域示例（勿与北京 Key 混用）：
# VITE_DASHSCOPE_REGION=singapore
# VITE_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
